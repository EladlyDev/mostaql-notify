# Mostaql Notifier — secrets (NEVER commit the real .env). Copy to .env and fill in.
# constitution IX: secrets live here only, not in the settings table or code.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# Your private Telegram chat id (numeric). Talk to the bot once, then use @userinfobot or getUpdates.
TELEGRAM_CHAT_ID=123456789

# SQLAlchemy database URL. SQLite for the single-box MVP; switch to postgresql+psycopg://... on a VPS.
DATABASE_URL=sqlite:///./data/mostaql.db

# --- Dashboard (Feature 2) ---
# Set DASHBOARD_AUTH_ENABLED=false to run the dashboard with no login (local only).
# If auth is enabled, DASHBOARD_PASSWORD and DASHBOARD_SESSION_SECRET are REQUIRED (fail-loud).
DASHBOARD_AUTH_ENABLED=true
DASHBOARD_PASSWORD=choose-a-strong-password
DASHBOARD_SESSION_SECRET=any-long-random-string
# Allowed CORS origin for the Next.js frontend.
FRONTEND_ORIGIN=http://localhost:3000

# --- Personal pipeline & workspace (Feature 3) ---
# Where uploaded attachment files are stored on disk. Keep it under the backed-up ./data volume and
# OUTSIDE any public web path (files are streamed only through gated endpoints). Backups must include
# BOTH the database and this directory.
ATTACHMENTS_DIR=./data/attachments
