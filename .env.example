# Mostaql Notifier — secrets (NEVER commit the real .env). Copy to .env and fill in.
# constitution IX: secrets live here only, not in the settings table or code.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# Your private Telegram chat id (numeric). Talk to the bot once, then use @userinfobot or getUpdates.
TELEGRAM_CHAT_ID=123456789

# SQLAlchemy database URL. SQLite for the single-box MVP; switch to postgresql+psycopg://... on a VPS.
DATABASE_URL=sqlite:///./data/mostaql.db
